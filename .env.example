# .env.example
# -------------
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control — add it to .gitignore.
#
# cp .env.example .env

# ── GitHub API ────────────────────────────────────────────────────────────────
#
# Personal access token for the GitHub REST API.
#
# Without a token : 60  requests/hour  (hits the limit after ~6,000 commits)
# With a token    : 5,000 requests/hour (sufficient for most accounts)
#
# How to generate one (takes ~30 seconds):
#   1. github.com → click your avatar → Settings
#   2. Left sidebar → Developer settings → Personal access tokens
#   3. Choose "Fine-grained tokens" → Generate new token
#   4. Name it (e.g. "github-analysis"), set an expiry
#   5. Under "Repository access" choose "Public Repositories (read-only)"
#   6. No additional scopes/permissions needed for public data
#   7. Click Generate → copy the token below
#
GITHUB_TOKEN=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
